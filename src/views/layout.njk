{% extends "govuk/template.njk" %}
{# 1. Set the page title #}
{% block pageTitle %}
  {% if errorSummary and errorSummary.length > 0 %}Error:
  {% endif %}
  {{ title }} - Task Manager - GOV.UK
{% endblock %}
{# 2. Link your CSS from the /assets route we set up in app.ts #}
{% block head %}
  <link href="/assets/govuk-frontend.min.css" rel="stylesheet">
  {% endblock %}
  {# 3. Configure the Header #}
  {% block header %}
    {{ govukHeader({
    serviceName: "Task Manager",
    serviceUrl: "/tasks",
    navigation: [
      { href: "/tasks", text: "All tasks", active: (activeNav == 'list') },
      { href: "/tasks/new", text: "Add a task", active: (activeNav == 'new') }
    ]
  }) }}
  {% endblock %}
  {# 4. The main content wrapper #}
  {% block content %}
    <div class="govuk-width-container">
      <div class="govuk-grid-row">
        <div
          class="govuk-grid-column-two-thirds">
          {# Individual pages will inject their content here #}
          {% block mainContent %}{% endblock %}
        </div>
      </div>
    </div>
  {% endblock %}
  {# 5. Initialise the GOV.UK JavaScript at the end of the body #}
  {% block bodyEnd %}
    <script type="module" src="/assets/govuk-frontend.min.js"></script>
    <script type="module">
      import {initAll} from '/assets/govuk-frontend.min.js'
      initAll()
    </script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var errorLinks = document.querySelectorAll('.govuk-error-summary__list a');
        errorLinks.forEach(function (link) {
          link.addEventListener('click', function (e) {
            var href = this.getAttribute('href');
            if (href && href.startsWith('#')) {
              var target = document.querySelector(href);
              if (target) {
                target.focus();
              }
            }
          });
        });
      });
    </script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var firstError = document.querySelector('.govuk-input--error');
        if (firstError) {
          firstError.focus();
        }
      });
    </script>
  {% endblock %}